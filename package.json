{
  "name": "the-big-ide",
  "version": "0.1.5",
  "description": "Prototype of The Big IDE built with Electron and React",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "backend:web": "node server/web-backend.js",
    "dev:web": "concurrently -k \"npm:backend:web\" \"vite\"",
    "dev:web:ui": "vite",
    "build": "vite build",
    "build:app": "npm run build && electron-builder",
    "preview": "vite preview",
    "preview:web": "concurrently -k \"npm:backend:web\" \"vite preview\"",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:record": "playwright test --project=chromium",
    "release": "npm run build:app"
  },
  "keywords": [
    "electron",
    "react",
    "ide",
    "sandbox",
    "opencode"
  ],
  "author": "Artem Noskov <artem@noartem.ru>",
  "license": "GPL3",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "server/**/*",
    "index.html",
    "package.json",
    "README.md"
  ],
  "build": {
    "appId": "ru.noartem.thebigide",
    "productName": "The Big IDE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "index.html",
      "package.json",
      "README.md"
    ],
    "npmRebuild": false,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Development"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/lang-yaml": "^6.1.2",
    "@fontsource/ibm-plex-mono": "^5.2.6",
    "@fontsource/space-grotesk": "^5.2.7",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@uiw/react-codemirror": "^4.25.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-resizable-panels": "^2.1.7",
    "tailwind-merge": "^3.3.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.5.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^38.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "wait-on": "^8.0.5"
  }
}
